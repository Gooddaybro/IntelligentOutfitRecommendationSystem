{
  "annotations": {"list": []},
  "editable": true,
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP 请求速率",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (method, uri) (rate(http_server_requests_seconds_count[5m]))", "legendFormat": "{{method}} {{uri}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx 速率",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (uri) (rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]))", "legendFormat": "{{uri}}"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 延迟",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "P95"}],
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "订单创建结果",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (operation, outcome) (increase(app_order_creation_total[15m]))", "legendFormat": "{{operation}} / {{outcome}}"}],
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 8}
    },
    {
      "type": "timeseries",
      "title": "支付回调结果",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (outcome) (increase(app_payment_callbacks_total[15m]))", "legendFormat": "{{outcome}}"}],
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 8}
    }
  ],
  "refresh": "30s",

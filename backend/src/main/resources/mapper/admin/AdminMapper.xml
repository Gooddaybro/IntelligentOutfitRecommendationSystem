<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.recommendation.intelligentoutfitrecommendationsystem.admin.mapper.AdminMapper">

    <select id="countOnSaleProducts" resultType="long">
        SELECT COUNT(*)
        FROM product_spu
        WHERE status = 'on_sale'
    </select>

    <select id="countSkus" resultType="long">
        SELECT COUNT(*)
        FROM product_sku
    </select>

    <select id="countLowStockSkus" resultType="long">
        SELECT COUNT(*)
        FROM inventory
        WHERE available_stock &lt;= #{threshold}
    </select>

    <select id="countPendingShipmentOrders" resultType="long">
        SELECT COUNT(*)
        FROM sales_order
        WHERE status = 'PAID'
    </select>

    <select id="countAfterSaleOrders" resultType="long">
        SELECT COUNT(*)
        FROM after_sale_request
        WHERE status IN ('REQUESTED', 'PENDING', 'APPROVED')
    </select>

    <select id="countOrders" resultType="long">
        SELECT COUNT(*)
        FROM sales_order
    </select>

    <select id="sumPaidAmount" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(total_amount), 0)
        FROM sales_order
        WHERE status IN ('PAID', 'SHIPPED', 'COMPLETED')
    </select>
</mapper>
